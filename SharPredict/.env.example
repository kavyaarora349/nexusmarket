#!/usr/bin/env node
/**
 * Backend Indexer Environment Configuration Template
 * Copy to SharPredict/.env and fill in your values
 */

# ==============================================================================
# DATABASE
# ==============================================================================
MONGO_URI=mongodb://localhost:27017/sharpredict
PORT=3001

# ==============================================================================
# BLOCKCHAIN & CONTRACTS
# ==============================================================================
RPC_URL=https://api-testnet.shardeum.org/

# After running deploy script, fill these in:
MARKET_FACTORY_ADDRESS=0x...
DEPLOYER_ADDRESS=0x...

# ==============================================================================
# EVENT LISTENER CONFIGURATION
# ==============================================================================
# Starting block to listen from (use 0 for mainnet, or deployment block)
START_BLOCK=0

# Whether to index historical events
INDEX_HISTORICAL=true
